---
import BaseLayout from './BaseLayout.astro';

interface Props {
  title: string;
  description?: string;
  date: Date;
  tags?: string[];
  collection: string;
}

const { title, description, date, tags, collection } = Astro.props;
const formattedDate = date.toISOString().split('T')[0];
---
<BaseLayout title={title} description={description}>
  <article class="container section">
    <header style="margin-bottom: var(--space-xl); padding-bottom: var(--space-lg); border-bottom: 1px solid var(--border);">
      <p class="label" style="margin-bottom: var(--space-sm);">{collection}</p>
      <h1>{title}</h1>
      {description && <p style="margin-top: var(--space-md); color: var(--text-secondary);">{description}</p>}
      <div style="margin-top: var(--space-md); display: flex; gap: var(--space-md); align-items: center; flex-wrap: wrap;">
        <span style="font-size: 0.8rem; color: var(--text-tertiary);">{formattedDate}</span>
        {tags && tags.map(tag => <span class="tag">{tag}</span>)}
      </div>
    </header>
    <div class="prose">
      <slot />
    </div>
  </article>
</BaseLayout>

<style>
  .prose :global(h2) { margin-top: var(--space-xl); margin-bottom: var(--space-md); }
  .prose :global(h3) { margin-top: var(--space-lg); margin-bottom: var(--space-sm); }
  .prose :global(p) { margin-bottom: var(--space-md); }
  .prose :global(ul), .prose :global(ol) { margin: var(--space-md) 0; padding-left: var(--space-lg); color: var(--text-secondary); }
  .prose :global(li) { margin-bottom: var(--space-xs); }
  .prose :global(code) { background: var(--bg-surface); border: 1px solid var(--border); padding: 0.1em 0.4em; font-size: 0.875em; }
  .prose :global(pre) { background: var(--bg-surface); border: 1px solid var(--border); padding: var(--space-lg); overflow-x: auto; margin: var(--space-lg) 0; }
  .prose :global(blockquote) { border-left: 2px solid var(--accent); padding-left: var(--space-lg); margin: var(--space-lg) 0; color: var(--text-secondary); font-style: italic; }
</style>
