---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

const allNotes = await getCollection('notes', ({ data }) => !data.draft);
const sortedNotes = allNotes.sort((a, b) => b.data.date.getTime() - a.data.date.getTime());
---

<BaseLayout title="Notes">
    <div class="container section">
        <h1 style="margin-bottom: var(--space-lg);">Notes</h1>

        {
            sortedNotes.length === 0 ? (
                <p style="color: var(--text-tertiary); font-size: 0.875rem;">// Nothing here yet. Check back soon.</p>
            ) : (
                <div>
                    {sortedNotes.map((note) => {
                        const formatted = note.data.date.toISOString().split('T')[0];
                        const noteUrl = `/notes/${note.slug}`;
                        const isOneRuleNote = ['the-one-rule', 'the-non-impedance-principle', 'the-next-step-doctrine'].includes(note.slug);
                        return (
                            <a href={noteUrl} class="note-item" style="display: flex;">
                                <div style="flex: 1;">
                                    <h3 class="note-title" style="font-size: 1rem; margin-bottom: var(--space-xs);">
                                        {note.data.title}
                                    </h3>
                                    <div style="display: flex; gap: var(--space-sm); align-items: center;">
                                        <span class="tag tag--accent">{note.data.category}</span>
                                    </div>
                                    {isOneRuleNote && (
                                        <p style="margin-top: var(--space-xs); font-size: 0.8125rem; color: var(--text-tertiary);">
                                            Part of{' '}
                                            <a href="/one-rule" style="color: var(--text-tertiary); text-decoration: underline;">
                                                The One Rule Framework
                                            </a>{' '}
                                            →
                                        </p>
                                    )}
                                </div>
                                <span class="note-date">{formatted}</span>
                            </a>
                        );
                    })}
                </div>
            )
        }
    </div>
</BaseLayout>
